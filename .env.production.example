# ============================================================
# הדרך נקסט - Production Environment Variables
# ============================================================
# העתיקו קובץ זה ל-Vercel Environment Variables
# https://vercel.com/[project]/settings/environment-variables

# --- Clerk Authentication (REQUIRED) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Convex (REQUIRED) ---
NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud
CONVEX_DEPLOY_KEY=prod:xxxxx

# --- App Configuration (REQUIRED) ---
NEXT_PUBLIC_APP_URL=https://haderech.co.il
NEXT_PUBLIC_APP_NAME=הדרך

# --- AI Features (Convex env var) ---
# Set in Convex Dashboard → Settings → Environment Variables:
#   npx convex env set ANTHROPIC_API_KEY sk-ant-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Push Notifications (VAPID) ---
# Generate: npx web-push generate-vapid-keys --json
# Public key also set in Convex: npx convex env set VAPID_PUBLIC_KEY ...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BKSeHFW4CVX6sAvImUjsMAaabOOQBCkL-GIoDqFRPso-KZR_YHN6eIyEDFEf0L7K8kk1Jw-oVdBuMgWmivP8a5Y
# Private key ONLY in Convex: npx convex env set VAPID_PRIVATE_KEY ...
# VAPID_PRIVATE_KEY=XOsUbTzKoUbtdHAGV52OLSNeotppIuXQx7C9R2L-cUg

# --- Stripe Payments (Optional - enable when ready) ---
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_BASIC_PRICE_ID=price_xxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxx

# --- Email (Resend - Optional) ---
RESEND_API_KEY=re_xxxxx

# --- Analytics (Optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Demo Mode (DO NOT enable in production!) ---
# NEXT_PUBLIC_DEMO_MODE=false
