# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Convex
# Get from: https://dashboard.convex.dev → Project Settings
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:xxxxx

# Anthropic (Claude API) - for AI Chat Coach (Phase 16)
# IMPORTANT: Set this in Convex Dashboard → Settings → Environment Variables
# NOT in .env.local (Convex actions run server-side in Convex cloud)
# Command: npx convex env set ANTHROPIC_API_KEY sk-ant-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
